---
const pillars = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    title: 'AI & Search Systems',
    description:
      'Semantic search engines, RAG pipelines, MCP servers, and agent-based workflows connecting LLMs to real data sources.',
    glowColor: 'rgba(139, 92, 246, 0.5)',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" /></svg>`,
    title: 'Backend Engineering',
    description:
      'Scalable microservices with .NET, FastAPI, PostgreSQL, and Elasticsearch. Deployed with Docker and CI/CD pipelines.',
    glowColor: 'rgba(6, 182, 212, 0.5)',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" /></svg>`,
    title: 'Developer Tools',
    description:
      'Terminal utilities, CLI tools, and open-source productivity software. Built for developers who live in the terminal.',
    glowColor: 'rgba(16, 185, 129, 0.5)',
  },
];
---

<section id="about" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16" data-animate>
      <p class="text-sm font-mono text-primary-400 mb-3">// what I do</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Three pillars of my work
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {
        pillars.map((pillar, i) => (
          <div
            data-animate
            data-delay={String(i + 1)}
            class="spotlight-card glow-border group p-6 rounded-xl border border-surface-800 bg-surface-900/30 hover:border-surface-700 hover:bg-surface-900/60 transition-all duration-300"
            style={`--glow-color: ${pillar.glowColor};`}
          >
            <div class="relative z-10">
              <div class="w-12 h-12 rounded-lg bg-primary-600/10 border border-primary-600/20 flex items-center justify-center text-primary-400 mb-5 group-hover:bg-primary-600/20 transition-colors">
                <Fragment set:html={pillar.icon} />
              </div>
              <h3 class="text-lg font-semibold text-white mb-3">{pillar.title}</h3>
              <p class="text-surface-400 text-sm leading-relaxed">
                {pillar.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
