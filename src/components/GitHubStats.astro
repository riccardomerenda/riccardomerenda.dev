---
let repos = 10;
let languages = 4;
let totalStars = 2;

try {
  const res = await fetch('https://api.github.com/users/riccardomerenda/repos?per_page=100&sort=updated');
  if (res.ok) {
    const data = await res.json();
    repos = data.length;
    const langs = new Set(data.map((r: any) => r.language).filter(Boolean));
    languages = langs.size;
    totalStars = data.reduce((sum: number, r: any) => sum + (r.stargazers_count || 0), 0);
  }
} catch {
  // Use defaults
}

const stats = [
  { value: repos.toString(), label: 'Public repos', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>` },
  { value: languages.toString(), label: 'Languages', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>` },
  { value: totalStars.toString(), label: 'Stars', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>` },
  { value: '2013', label: 'Coding since', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>` },
];
---

<section class="py-24 md:py-32 border-t border-surface-800/50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16" data-animate>
      <p class="text-sm font-mono text-primary-400 mb-3">// open source</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">GitHub at a glance</h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {
        stats.map((stat, i) => (
          <div
            data-animate
            data-delay={String(i + 1)}
            class="spotlight-card glow-border p-6 rounded-xl border border-surface-800 bg-surface-900/30 text-center"
            style="--glow-color: rgba(99, 102, 241, 0.4);"
          >
            <div class="relative z-10">
              <div class="flex justify-center mb-3 text-surface-500">
                <Fragment set:html={stat.icon} />
              </div>
              <div class="text-2xl md:text-3xl font-bold text-white mb-1">{stat.value}</div>
              <div class="text-xs font-mono text-surface-500 uppercase tracking-wider">{stat.label}</div>
            </div>
          </div>
        ))
      }
    </div>

    <div data-animate data-delay="2" class="mt-8 text-center">
      <a
        href="https://github.com/riccardomerenda"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-surface-400 hover:text-white transition-colors group"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        View full profile on GitHub
        <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
