---
const projects = [
  {
    title: 'driftcut',
    tagline: 'Early-stop canary testing for LLM model migrations',
    description:
      'Decision gating tool that evaluates quality, latency, and cost before committing to a full LLM model swap. Stratified sampling, parallel execution, and an intelligent decision engine.',
    tech: ['Python', 'LiteLLM', 'SQLite', 'Async I/O', 'Pydantic'],
    github: 'https://github.com/riccardomerenda/driftcut',
    glowColor: 'rgba(139, 92, 246, 0.5)',
    accentClass: 'text-violet-400',
    terminalLines: [
      { prompt: true, text: 'driftcut evaluate --model gpt-4.1' },
      { prompt: false, text: '▸ Sampling 150 prompts across 8 categories...' },
      { prompt: false, text: '▸ Quality: 94.2%  Latency: -12ms  Cost: -$0.03' },
      { prompt: false, text: '✓ Decision: PROCEED' },
    ],
  },
  {
    title: 'elastic-mcp',
    tagline: 'MCP Server for Elasticsearch',
    description:
      'Lets any AI agent — Claude, Copilot, Cursor — query Elasticsearch via natural language. Pure translator between MCP protocol and ES API. The intelligence lives in the client.',
    tech: ['C#', '.NET 10', 'MCP Protocol', 'Elasticsearch 9', 'xUnit'],
    github: 'https://github.com/riccardomerenda/elastic-mcp',
    glowColor: 'rgba(6, 182, 212, 0.5)',
    accentClass: 'text-cyan-400',
    terminalLines: [
      { prompt: true, text: 'elastic-mcp --index logs-*' },
      { prompt: false, text: '▸ MCP server listening on stdio' },
      { prompt: false, text: '▸ Tools: search, semantic_search, aggregate' },
      { prompt: false, text: '▸ Resources: 12 indices mapped' },
    ],
  },
  {
    title: 'logq',
    tagline: 'Fast, interactive log explorer for the terminal',
    description:
      'Treats log files as queryable databases. Live filtering, time histograms, JSON drill-down, trace following, pattern clustering. Zero external dependencies.',
    tech: ['Go', 'Zero deps', 'Inverted indexes', 'Binary search'],
    github: 'https://github.com/riccardomerenda/logq',
    glowColor: 'rgba(16, 185, 129, 0.5)',
    accentClass: 'text-emerald-400',
    terminalLines: [
      { prompt: true, text: 'logq app.log -f' },
      { prompt: false, text: '▸ 142,891 records indexed in 0.3s' },
      { prompt: false, text: '▸ Filter: level:error @last-1h' },
      { prompt: false, text: '▸ 23 matches · 4 clusters found' },
    ],
  },
  {
    title: 'steplight',
    tagline: 'Local-first trace inspector for LLM agents',
    description:
      'Load a trace, inspect what happened, and understand why. Debug agent runs with timelines, tool calls, retries, token usage, latencies, and diagnostics — all from the terminal.',
    tech: ['Python', 'Textual', 'Typer', 'OTEL Traces', 'HTML Export'],
    github: 'https://github.com/riccardomerenda/steplight',
    glowColor: 'rgba(245, 158, 11, 0.5)',
    accentClass: 'text-amber-400',
    terminalLines: [
      { prompt: true, text: 'steplight trace.json' },
      { prompt: false, text: '▸ 42 spans loaded · 3 tool calls · 2 retries' },
      { prompt: false, text: '▸ Tokens: 12,840 in / 3,210 out' },
      { prompt: false, text: '▸ Total latency: 4.2s · Cost: $0.08' },
    ],
  },
];
---

<section id="projects" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16" data-animate>
      <p class="text-sm font-mono text-primary-400 mb-3">// featured projects</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Things I've built</h2>
      <p class="text-surface-400 mt-4 max-w-2xl">
        Open-source tools and systems at the intersection of AI infrastructure, backend
        engineering, and developer experience.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {
        projects.map((project, i) => (
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            data-animate
            data-delay={String((i % 2) + 1)}
            class="spotlight-card glow-border group block rounded-xl border border-surface-800 bg-surface-900/30 transition-all duration-300 hover:border-surface-700"
            style={`--glow-color: ${project.glowColor};`}
          >
            {/* Mini terminal preview */}
            <div class="px-4 pt-4 relative z-10">
              <div class="rounded-t-lg border border-surface-700/50 border-b-0 bg-surface-950/80 overflow-hidden">
                <div class="flex items-center gap-1.5 px-3 py-2 border-b border-surface-800/50">
                  <div class="w-2 h-2 rounded-full bg-surface-700" />
                  <div class="w-2 h-2 rounded-full bg-surface-700" />
                  <div class="w-2 h-2 rounded-full bg-surface-700" />
                  <span class="text-[10px] text-surface-600 font-mono ml-2">{project.title}</span>
                </div>
                <div class="px-3 py-2.5 font-mono text-[11px] leading-relaxed">
                  {project.terminalLines.map((line) => (
                    <div class={line.prompt ? 'text-surface-400' : 'text-surface-500'}>
                      {line.prompt && <span class={project.accentClass}>$ </span>}
                      {line.text}
                    </div>
                  ))}
                </div>
              </div>
            </div>

            {/* Card content */}
            <div class="p-6 pt-4 relative z-10">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="text-xl font-semibold text-white group-hover:text-primary-300 transition-colors">
                    {project.title}
                  </h3>
                  <p class="text-sm text-surface-400 mt-1">{project.tagline}</p>
                </div>
                <svg
                  class="w-5 h-5 text-surface-600 group-hover:text-surface-400 transition-all group-hover:-translate-y-0.5 group-hover:translate-x-0.5 shrink-0 mt-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M7 17L17 7M17 7H7M17 7v10"
                  />
                </svg>
              </div>

              <p class="text-sm text-surface-400 leading-relaxed mb-4">
                {project.description}
              </p>

              <div class="flex flex-wrap gap-2">
                {project.tech.map((t) => (
                  <span class="px-2.5 py-1 text-xs font-mono rounded-md bg-surface-800/80 text-surface-300 border border-surface-700/50">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
