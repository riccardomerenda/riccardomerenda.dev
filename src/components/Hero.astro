<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Animated gradient mesh background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="mesh-blob-1 absolute -top-32 -right-32 w-[500px] h-[500px] bg-primary-600/15 rounded-full blur-[128px]"></div>
    <div class="mesh-blob-2 absolute top-1/2 -left-48 w-[400px] h-[400px] bg-accent-500/10 rounded-full blur-[128px]"></div>
    <div class="mesh-blob-3 absolute -bottom-24 right-1/3 w-[350px] h-[350px] bg-violet-500/8 rounded-full blur-[128px]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 py-32 md:py-40">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left: Text content -->
      <div>
        <div
          data-animate
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-surface-800 bg-surface-900/50 text-xs text-surface-400 mb-8"
        >
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Available for opportunities
        </div>

        <h1 data-animate data-delay="1" class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Building the
          <span
            class="bg-gradient-to-r from-primary-400 to-accent-400 bg-clip-text text-transparent"
            >infrastructure</span
          ><br />
          between AI and data
        </h1>

        <p data-animate data-delay="2" class="text-lg text-surface-400 leading-relaxed mb-10 max-w-lg">
          Senior Software Engineer specializing in AI tooling, backend systems, and developer
          tools. I build the plumbing that connects AI agents to real-world data.
        </p>

        <div data-animate data-delay="3" class="flex flex-wrap gap-4">
          <a
            href="#projects"
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary-600 hover:bg-primary-500 text-white font-medium transition-all hover:shadow-lg hover:shadow-primary-600/25"
          >
            View my work
            <svg class="w-4 h-4 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
          <a
            href="#contact"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-surface-700 hover:border-surface-500 text-surface-300 hover:text-white font-medium transition-all"
          >
            Get in touch
          </a>
        </div>
      </div>

      <!-- Right: Terminal card -->
      <div data-animate data-delay="2" class="hidden md:block">
        <div class="spotlight-card glow-border rounded-xl border border-surface-800 bg-surface-900/60 backdrop-blur-sm overflow-hidden shadow-2xl" style="--glow-color: rgba(99, 102, 241, 0.4);">
          <!-- Terminal header -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-surface-800 relative z-10">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <span class="text-xs text-surface-500 font-mono ml-2">~/riccardo</span>
          </div>
          <!-- Terminal body -->
          <div class="p-5 font-mono text-sm leading-relaxed relative z-10">
            <div class="text-surface-500">
              <span class="text-accent-400">$</span> cat about.json
            </div>
            <div class="mt-3 text-surface-300">
              <span class="text-surface-500">&#123;</span><br />
              <span class="ml-4 text-primary-400">"role"</span><span class="text-surface-500">:</span>
              <span class="text-emerald-400">"Senior Software Engineer"</span><span class="text-surface-500">,</span><br />
              <span class="ml-4 text-primary-400">"focus"</span><span class="text-surface-500">:</span>
              <span class="text-emerald-400">"AI Infrastructure"</span><span class="text-surface-500">,</span><br />
              <span class="ml-4 text-primary-400">"languages"</span><span class="text-surface-500">: [</span><br />
              <span class="ml-8 text-emerald-400">"C#"</span><span class="text-surface-500">,</span>
              <span class="text-emerald-400">"Python"</span><span class="text-surface-500">,</span>
              <span class="text-emerald-400">"Go"</span><span class="text-surface-500">,</span>
              <span class="text-emerald-400">"TypeScript"</span><br />
              <span class="ml-4 text-surface-500">],</span><br />
              <span class="ml-4 text-primary-400">"building"</span><span class="text-surface-500">: [</span><br />
              <span class="ml-8 text-emerald-400">"MCP Servers"</span><span class="text-surface-500">,</span><br />
              <span class="ml-8 text-emerald-400">"LLM Testing Tools"</span><span class="text-surface-500">,</span><br />
              <span class="ml-8 text-emerald-400">"Developer CLIs"</span><br />
              <span class="ml-4 text-surface-500">],</span><br />
              <span class="ml-4 text-primary-400">"location"</span><span class="text-surface-500">:</span>
              <span class="text-emerald-400">"Sicily, Italy"</span><br />
              <span class="text-surface-500">&#125;</span>
            </div>
            <div class="mt-3">
              <span class="text-accent-400">$</span>
              <span class="inline-block w-2 h-4 bg-surface-400 animate-pulse ml-1"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
