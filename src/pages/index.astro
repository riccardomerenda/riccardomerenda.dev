    <!-- ══════════ CONTACT ══════════ -->
    <section id="contact" class="relative py-28 md:py-44 border-t border-ink-800 overflow-hidden">
      <div class="aura w-[600px] h-[600px] left-1/2 -translate-x-1/2 bottom-[-300px]" style="background: color-mix(in srgb, var(--color-signal-500) 10%, transparent);"></div>
      <div class="relative mx-auto max-w-7xl px-6 lg:px-10 text-center">
        <p data-reveal class="font-mono text-[13px] text-signal-500 mb-7">// let’s build something</p>
        <h2 data-reveal data-reveal-d="1" class="display text-5xl md:text-8xl text-ink-50 mb-10">
          Let’s <span class="text-gradient">connect.</span>
        </h2>
        <p data-reveal data-reveal-d="2" class="text-ink-400 leading-relaxed max-w-xl mx-auto mb-12">
          Always up for discussing AI infrastructure, open-source tooling, and hard
          engineering problems. The inbox is open.
        </p>

        <div data-reveal data-reveal-d="3" class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a id="email-link" href="#" data-cursor class="magnetic group inline-flex items-center gap-3 rounded-full bg-signal-500 px-8 py-4 font-medium text-ink-950 hover:bg-signal-400 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            <span id="email-text">say hello</span>
          </a>
          <div class="flex items-center gap-3">
            <a href="https://github.com/riccardomerenda" target="_blank" rel="noopener noreferrer" data-cursor class="magnetic inline-flex items-center justify-center w-12 h-12 rounded-full border border-ink-700 text-ink-300 hover:border-signal-500 hover:text-signal-500 transition-colors" aria-label="GitHub">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
